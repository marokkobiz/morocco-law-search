APP_NAME="Morocco Law Search"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=marocloi
DB_USERNAME=root
DB_PASSWORD=

QUEUE_CONNECTION=database
SESSION_DRIVER=file
CACHE_STORE=file

# --- AI / Embeddings ---
AI_PROVIDER=ollama
AI_API_KEY=
AI_BASE_URL=http://localhost:11434
AI_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
LEGAL_SEMANTIC_SEARCH_ENABLED=true

# --- Billing (optional) ---
BILLING_REQUIRE_PAYMENT=false
STRIPE_SECRET=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Corpus Update Schedule ---
LEGAL_SOURCE_UPDATE_DAILY_AT=03:00
LEGAL_SOURCE_UPDATE_TIMEZONE=Africa/Casablanca
LEGAL_SOURCE_OFFICIAL_BULLETINS_ENABLED=true

# --- AI Web Crawler ---
CRAWLER_MAX_DEPTH=3
CRAWLER_DOMAIN_RESTRICT=true

# --- OCR (optional, machine-specific paths) ---
CRAWLER_TESSERACT_BIN=
CRAWLER_TESSERACT_DATA_DIR=
CRAWLER_PDFTOPPM_BIN=
