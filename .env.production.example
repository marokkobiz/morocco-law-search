APP_NAME="Marokko Biz Law Search"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=marokkobiz_law
DB_USERNAME=
DB_PASSWORD=

AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_TIMEOUT_SECONDS=30
LEGAL_SEMANTIC_SEARCH_ENABLED=true
LEGAL_SEMANTIC_SEARCH_MIN_SCORE=0.55
AI_PLANNER_TIMEOUT_MS=60000
AI_ANSWER_TIMEOUT_MS=120000
TRANSLATION_TIMEOUT_SECONDS=12

BILLING_REQUIRE_PAYMENT=true
BILLING_DEFAULT_TRIAL_DAYS=0
STRIPE_SECRET=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

LEGAL_SOURCE_UPDATE_COMMAND="corpus:update-official-sources --source=all --embed"
LEGAL_SOURCE_UPDATE_DAILY_AT=03:00
LEGAL_SOURCE_UPDATE_TIMEZONE=Africa/Casablanca
LEGAL_SOURCE_OFFICIAL_BULLETINS_ENABLED=true

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
